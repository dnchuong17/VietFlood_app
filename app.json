{
  "expo": {
    "name": "VietFlood",
    "slug": "vietflood",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.vietflood.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VietFlood needs your location to show flood zones and relief operations.",
        "NSCameraUsageDescription": "Camera access is needed to capture flood damage photos for reports.",
        "NSPhotoLibraryUsageDescription": "Photo library access is needed to upload images for reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.vietflood.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermissions": "Allow VietFlood to access your location data for flood monitoring and relief operations."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow VietFlood to access your camera for taking photos of flood damage."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "12345678-1234-1234-1234-123456789012"
      }
    },
    "scheme": "vietflood",
    "updates": {
      "url": "https://u.expo.dev/12345678-1234-1234-1234-123456789012",
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
